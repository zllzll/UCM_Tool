<?xml version="1.0" encoding="utf-8"?>
<Settings>
  <!--主题颜色-->
  <set key="ThemeColor" value="Blue" />
  <!--********图表参数*********-->
  <!--0显示点云和跟踪；1显示点云；2：显示跟踪-->
  <set key="DisplayTargetType" value="0" />
  <!--3D立体图目标大小-->
  <set key="PointSize" value="3" />
  <set key="TrackSize" value="0.5" />
  <!--3D立体图 显示颜色条-->
  <set key="View3D_ColorPan" value="false" />
  <!--X Min 整数   必须小于XMax-->
  <set key="XMin" value="-50" />
  <!--X Max 整数   必须大于XMin-->
  <set key="XMax" value="50" />
  <!--X Step   View3D步长-->
  <set key="XStep" value="10" />
  <!--Y Min 整数   必须小于YMax-->
  <set key="YMin" value="0" />
  <!--Y Max 整数   必须大于XMin-->
  <set key="YMax" value="200" />
  <!--Y Step   View3D步长-->
  <set key="YStep" value="10" />
  <!--Z Min 整数   必须小于ZMax-->
  <set key="ZMin" value="-20" />
  <!--Z Max 整数   必须大于ZMin-->
  <set key="ZMax" value="20" />
  <!--Z Step   View3D步长-->
  <set key="ZStep" value="5" />
  <!--累计帧数：累积多少帧目标一起显示-->
  <set key="CumulativeFrameNum" value="1" />
  <!--累计帧数方式,0：超过CumulativeFrameNum帧数之后一直保持最新CumulativeFrameNum帧数-->
  <!--累计帧数方式,1：超过CumulativeFrameNum帧数之后清空重新累计-->
  <set key="CumulativeFrameType" value="0" />
  <!--是否硬件加速-->
  <set key="HardwareAcc" value="false" />
  <!--是否显示XZ和YZ平面网格-->
  <set key="B_OtherGrid" value="true" />
  <!--********图表参数*********-->

  <!--********文件存储参数*********-->
  <!--数据储存-->
  <set key="TargetData" value="false" />
  <!--文件大小-->
  <set key="FileSize" value="5" />
  <!--文件路径-->
  <set key="FileRoute" value="C:\\SR75_Data\" />
  <!--********文件存储参数*********-->

  <!--********连接配置*********-->
  <!--雷达名称-->
  <set key="RadarType" value="UCM211" />
  <!--通讯类型 CANFD TCP COM-->
  <set key="ConnType" value="TCP" />
  <!--********CAN/CANFD参数*********-->
  <!--CAN类型 CAN，CANFD 不同设备名称所属CAN类型不一致-->
  <set key="Zlg_Type" value="CANFD" />
  <!--CAN设备厂家 CX:创芯 ZLG：周立功-->
  <set key="CAN_Company" value="ZLG" />
  <!--CAN设备名称-->
  <set key="Zlg_CAN_Type" value="CANFD-TCP-SELF" />
  <!--设备索引-->
  <set key="CAN_Index" value="0" />
  <!--通道 默认0-->
  <set key="CAN_Channel" value="0" />
  <!--工作模式：0代表正常模式，1代表只听模式-->
  <set key="WorkMode" value="0" />
  <!--CANFD标准:0代表ISO；1代表BOSCH  默认0-->
  <set key="CANFD_Standard" value="0" />
  <!--仲裁域波特率-->
  <set key="CANFD_Baud_Abit" value="0x00018B2E" />
  <!--数据域波特率-->
  <set key="CANFD_Baud_Dbit" value="0x0001020A" />
  <!--CAN波特率-->
  <set key="CAN_Baud" value="0x0014" />
  <!--********CAN/CANFD参数*********-->
  <!--********TCP参数*********-->
  <!--TCP-->
  <set key="TCP_IP" value="192.168.10.10" />
  <!--TCP-->
  <set key="TCP_Port" value="50000" />
<!--********TCP参数*********-->
  <!--********COM参数*********-->
  <!--串口号-->
  <set key="COM_No" value="COM1" />
  <!--串口波特率-->
  <set key="COM_Baud" value="460800" />
  <!--串口校验位-->
  <set key="COM_Parity" value="None" />
  <!--串口数据位-->
  <set key="COM_DataBit" value="8" />
  <!--串口停止位-->
  <set key="COM_StopBit" value="One" />
<!--********COM参数*********-->
  <!--********连接配置*********-->
	
  <!--********颜色高度配置*********-->
  <!--默认颜色：true；按高度设置颜色：false-->
  <set key="DefaultColor" value="false" />
  <!--超过该值都为红色（不包含该值）-->
  <set key="RedValue" value="1000" />
  <!--小于红色值大于该值为橙色（不包含该值）-->
  <set key="OrangeValue" value="4" />
  <!--小于橙色值大于该值为黄色（不包含该值）-->
  <set key="YellowValue" value="3" />
  <!--小于黄色值大于该值为绿色（不包含该值）-->
  <set key="GreenValue" value="2" />
  <!--小于绿色值大于该值为青色（不包含该值）-->
  <set key="CyanValue" value="1" />
  <!--小于青色值大于该值为蓝色（不包含该值）小于该值为紫色-->
  <set key="BlueValue" value="0" />
  <!--********颜色高度配置*********-->

  <!--********文本配置*********-->
  <!--显示点云目标文本-->
  <set key="DisplayText" value="false" />
  <!--显示跟踪目标文本-->
  <set key="DisplayTrackText" value="false" />
  <!--跟踪点颜色-->
  <set key="TrackColor" value="-65536" />
  <!--跟踪点颜色模式 0：默认跟踪点颜色  1：ID着色模式-->
  <set key="TrackColorMode" value="1" />
  <!--跟踪文本颜色-->
  <set key="TrackTextColor" value="-65536" />
  <!--跟踪文本大小-->
  <set key="TrackTextSize" value="40" />
  <!--跟踪文本远近大小一致：true=距离补偿缩放，false=当前行为-->
  <set key="TrackTextFixedSize" value="true" />
  <!--跟踪文本缩放倍率（默认2.0），仅在TrackTextFixedSize=true时生效-->
  <set key="TrackTextScale" value="0.1" />
  <!--距离补偿参考距离（默认50米），仅在TrackTextFixedSize=true时生效-->
  <set key="TrackTextRefDistance" value="40" />
  <!--坐标轴刻度文字远近大小一致：true=距离补偿缩放，false=当前行为-->
  <set key="AxisTextFixedSize" value="true" />
  <!--坐标轴文字缩放倍率（默认2.0），仅在AxisTextFixedSize=true时生效-->
  <set key="AxisTextScale" value="1.5" />
  <!--3D:false还是2D:true -->
  <set key="UseScreenSpaceText" value="false" />
  <!--原生方式:false还是GDI文本:true -->
  <set key="UseGdiTextOverlay" value="false" />
  <!--2D文本固定字体大小（像素），设为0表示使用旧版距离衰减模式-->
  <set key="Text2DFontSize" value="14" />
  <!--3D显示最大文本数量限制 -->
  <set key="Max3DTextCount" value="100" />
  <!--2D显示最大文本数量限制 -->
  <set key="Max2DTextCount" value="100" />
  <!--空间哈希网格筛选目标 单位m-->
  <set key="Grid_Size" value="5" />
  <!--ID显示-->
  <set key="Tar_ID" value="false" />
  <!--X显示-->
  <set key="Tar_X" value="false" />
  <!--Y显示-->
  <set key="Tar_Y" value="false" />
  <!--Z显示-->
  <set key="Tar_Z" value="false" />
  <!--V显示-->
  <set key="Tar_V" value="false" />
  <!--A显示-->
  <set key="Tar_A" value="false" />
  <!--C显示-->
  <set key="Tar_C" value="false" />
  <!--启用时true：vtkTextActor3D 对象被复用，避免每帧创建/销毁-->
  <!--禁用时false：文本Actor在清理时直接销毁，内存占用略低但GC频繁-->
  <set key="EnableVtkObjectPool" value="true" />
  <!--********文本配置*********-->
  <!--********跟踪轨迹*********-->
  <!--是否显示-->
  <set key="DisplayTrackTrajectory" value="true" />
  <!--跟踪轨迹线宽-->
  <set key="TrackTrajectoryLineWidth" value="2" />
  <!--跟踪轨迹颜色-->
  <set key="TrackTrajectoryColor" value="-65536" />
  <!--每条跟踪轨迹最大历史点 最大2600会降-->
  <set key="TrackTrajectoryPointCount" value="500" />
  <!--清除轨迹条件0：超时清除；其他没有这个ID就清除-->
  <set key="ClearTrackTrajectoryType" value="1" />
  <!--每条跟踪轨迹超过多少毫秒没来此ID 清除掉轨迹-->
  <set key="TrackTrajectoryTime" value="500" />
  <!--轨迹增量渲染：true=每帧只追加新线段（高性能），false=每帧全量重建（旧方案）-->
  <set key="TrackTrajectoryIncremental" value="true" />
  <!--渲染间隔(ms)：0=每帧渲染，>0=隔N毫秒渲染一次（节省CPU/GPU），推荐200-->
  <set key="RenderIntervalMs" value="150" />
  <!--跟踪目标ID过滤，逗号分隔如"1,2,3,4"，为空显示全部-->
  <set key="FilterTrackIds" value="" />
  <!--********跟踪轨迹*********-->
  <!--********视频预览*********-->
  <!--历史RTSP流-->
  <set key="RTSPStream" value="rtsp://192.168.10.66/live/0" />
  <!--是否加时间戳-->
  <set key="B_AddTimestamp" value="true" />
  <!--********视频预览*********-->
  <!--********数据回放*********-->
  <!--显示数据回放功能-->
  <set key="ShowDataReplay" value="true" />
  <!--数据回放格式选择-->
  <set key="DataReplayFormatType" value="1" />
  <!--数据回放帧周期  ms-->
  <set key="DataReplayFrameCycle" value="25" />
  <!--********数据回放*********-->
  <set key="ShowAlive" value="False" />
  <!--升级发送0x104等待时间 小于等于0不等待-->
  <set key="SendWaitTime" value="0" />
  <!--若协议中存在帧时间时使用。点云和跟踪目标周期时间的取值 0：取获取完整帧时间 1:取雷达提供的时间-->
  <set key="GetTimeType" value="0" />
  <!--非等比例缩放-->
  <set key="NonUniformScale" value="false" />
  <!--VTK背景色 true:白色-->
  <set key="VTKBackColor" value="true" />
  <!--部分雷达需升级完成回复后等待雷达升级重启 单位毫秒   0时不等待-->
  <set key="WaitUpgradeEndTime" value="30000" />
  <!--代表1、VTK失去焦点的时候多久渲染一次所有对象-->
  <set key="VtkDrawTimeInLostFocus" value="0" />
</Settings>