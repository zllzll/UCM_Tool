<?xml version="1.0" encoding="utf-8"?>
<Settings>
  <!--********图标参数*********-->
  <!--是否显示网格-->
  <set key="IsDisplayGrid" value="true" />
  <!--刷新Nplot定时时间ms-->
  <set key="RefreshTimeCnt" value="100" />
  <!--3D立体图-->
  <set key="View3D" value="true" />
  <!--3D立体图目标大小-->
  <set key="PointSize" value="3" />
  <!--3D立体图 显示颜色条-->
  <set key="View3D_ColorPan" value="false" />
  <!--3D立体图 显示3D目标文本-->
  <set key="Display3DText" value="true" />
  <!--View3D 初始化角度  暂时只支持0°和-90°-->
  <set key="InitAngle" value="-90" />
  <!--X Min 整数   必须小于XMax-->
  <set key="XMin" value="-40" />
  <!--X Max 整数   必须大于XMin-->
  <set key="XMax" value="40" />
  <!--X Step   View3D步长-->
  <set key="XStep" value="5" />
  <!--Y Min 整数   必须小于YMax-->
  <set key="YMin" value="0" />
  <!--Y Max 整数   必须大于XMin-->
  <set key="YMax" value="100" />
  <!--Y Step   View3D步长-->
  <set key="YStep" value="5" />
  <!--Z Min 整数   必须小于ZMax-->
  <set key="ZMin" value="-6" />
  <!--Z Max 整数   必须大于ZMin-->
  <set key="ZMax" value="6" />
  
  <!--********图标参数*********-->

  <!--********文件存储参数*********-->
  <!--数据储存-->
  <set key="TargetData" value="False" />
  <!--文件大小-->
  <set key="FileSize" value="500" />
  <!--文件路径-->
  <set key="FileRoute" value="C:\\SR75_Data\" />
  <!--********文件存储参数*********-->

  <!--********连接配置*********-->
  <!--CAN类型 CAN，CANFD 使用不同方式请做调整-->
  <set key="Zlg_Type" value="CANFD" />
  <!--CAN类型 CAN，CANFD-->
  <set key="Zlg_CAN_Type" value="USBCANFD-200U" />
  <!--设备索引-->
  <set key="CAN_Index" value="0" />
  <!--通道 默认0-->
  <set key="CAN_Channel" value="0" />
  <!--工作模式：0代表正常模式，1代表只听模式-->
  <set key="WorkMode" value="0" />
  <!--CANFD标准:0代表ISO；1代表BOSCH  默认0-->
  <set key="CANFD_Standard" value="0" />
  <!--仲裁域波特率-->
  <set key="CANFD_Baud_Abit" value="0x00018B2E" />
  <!--数据域波特率-->
  <set key="CANFD_Baud_Dbit" value="0x00010207" />
  <!--CAN波特率-->
  <set key="CAN_Baud" value="0x0014" />
  <!--********连接配置*********-->

  <!--速度选择-->
  <set key="VelSelect" value="3" />
  <!--********颜色高度配置*********-->
  <!--超过该值都为红色（不包含该值）-->
  <set key="RedValue" value="1000" />
  <!--小于红色值大于该值为橙色（不包含该值）-->
  <set key="OrangeValue" value="4" />
  <!--小于橙色值大于该值为黄色（不包含该值）-->
  <set key="YellowValue" value="3" />
  <!--小于黄色值大于该值为绿色（不包含该值）-->
  <set key="GreenValue" value="2" />
  <!--小于绿色值大于该值为青色（不包含该值）-->
  <set key="CyanValue" value="1" />
  <!--小于青色值大于该值为蓝色（不包含该值）小于该值为紫色-->
  <set key="BlueValue" value="0" />
  <!--********颜色高度配置*********-->

  <!--********文本配置*********-->
  <!--ID显示-->
  <set key="Tar_ID" value="true" />
  <!--X显示-->
  <set key="Tar_X" value="False" />
  <!--Y显示-->
  <set key="Tar_Y" value="False" />
  <!--Z显示-->
  <set key="Tar_Z" value="False" />
  <!--********文本配置*********-->
  <!--显示视频-->
  <set key="Is_Video" value="False" />
  <!--zlgcan.dll所属厂家  ZLG：周立功；CX：创芯-->
  <set key="CANFactory" value="CX" />
</Settings>